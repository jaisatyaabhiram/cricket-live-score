<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= tournament.name %> - Tournament Details</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
        .player-item { display: flex; justify-content: space-between; align-items: center; padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-radius: var(--radius-sm); margin-bottom: 0.5rem; }
        .search-results { position: absolute; top: 100%; left: 0; right: 0; background: #1a1a1a; border: 1px solid var(--border-glass); border-radius: var(--radius-sm); z-index: 10; max-height: 200px; overflow-y: auto; display: none; }
        .search-item { padding: 0.8rem; cursor: pointer; transition: 0.2s; }
        .search-item:hover { background: var(--accent-primary); color: white; }
        .team-card { background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass); padding: 1rem; border-radius: var(--radius-md); margin-bottom: 1.5rem; }
        .team-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-glass); }
        .squad-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
        .squad-tag { background: var(--accent-primary-glass); color: var(--accent-primary); padding: 0.3rem 0.6rem; border-radius: 20px; font-size: 0.75rem; border: 1px solid var(--accent-primary); }
    </style>
</head>
<body class="admin-body">
    <%- include('../partials/header') %>
    
    <main class="container admin-container">
        <div class="dashboard-header">
            <div class="header-titles">
                <h1><%= tournament.name %></h1>
                <p><%= tournament.description %></p>
            </div>
            <div style="display: flex; gap: 1rem;">
                <a href="/organizer/dashboard" class="btn-secondary">Back to Dashboard</a>
                <a href="/organizer/create-match?tournamentId=<%= tournament.id %>" class="btn-primary">Add Match</a>
            </div>
        </div>
        
        <div class="detail-grid">
            <div class="stat-box glass-panel">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3>Tournament Schedule & Results</h3>
                    <div class="search-box glass-panel" style="padding: 0.3rem 0.8rem; display: flex; align-items: center; gap: 0.4rem; background: rgba(255,255,255,0.03); width: 200px;">
                        <span style="font-size: 0.8rem;">🔍</span>
                        <input type="text" id="fixture-search" placeholder="Filter fixtures..." style="background: transparent; border: none; color: white; width: 100%; font-size: 0.75rem; outline: none;">
                    </div>
                </div>
                <div class="matches-list" id="fixtures-list">
                    
                    <!-- Live Matches -->
                    <% if (matches.live.length > 0) { %>
                        <h4 style="color: var(--danger); font-size: 0.8rem; text-transform: uppercase; margin: 1rem 0 0.5rem;">🔴 Live Now</h4>
                        <% matches.live.forEach(match => { %>
                            <div class="player-row" style="padding: 1rem; cursor: pointer; border-left: 3px solid var(--danger);" onclick="window.location.href='/organizer/update-match/<%= match.id %>'">
                                <div style="flex: 2; font-weight: 600;"><%= match.team1 %> vs <%= match.team2 %></div>
                                <div style="flex: 1; text-align: right; font-weight: bold;"><%= match.team1Score.runs %>/<%= match.team1Score.wickets %> vs <%= match.team2Score.runs %>/<%= match.team2Score.wickets %></div>
                            </div>
                        <% }); %>
                    <% } %>

                    <!-- Upcoming (Fixtures) -->
                    <h4 style="color: var(--accent-secondary); font-size: 0.8rem; text-transform: uppercase; margin: 1.5rem 0 0.5rem;">📅 Future Fixtures</h4>
                    <% if (matches.upcoming.length > 0) { %>
                        <% matches.upcoming.forEach(match => { %>
                            <div class="player-row" style="padding: 1rem; cursor: pointer;" onclick="window.location.href='/organizer/update-match/<%= match.id %>'">
                                <div style="flex: 2; font-weight: 600;"><%= match.team1 %> vs <%= match.team2 %></div>
                                <div style="flex: 1; text-align: right; font-size: 0.8rem; color: var(--text-muted);"><%= new Date(match.matchDate).toLocaleDateString() %></div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p style="color: var(--text-muted); font-size: 0.8rem; padding-left: 0.5rem;">No upcoming matches scheduled.</p>
                    <% } %>

                    <!-- Finished -->
                    <% if (matches.finished.length > 0) { %>
                        <h4 style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; margin: 1.5rem 0 0.5rem;">✅ Results</h4>
                        <% matches.finished.forEach(match => { %>
                            <div class="player-row" style="padding: 1rem; opacity: 0.9;" onclick="window.location.href='/match/<%= match.id %>'">
                                <div style="flex: 2;">
                                    <div style="font-weight: 600;"><%= match.team1 %> vs <%= match.team2 %></div>
                                    <% if (match.matchResult) { %>
                                        <div style="font-size: 0.75rem; color: var(--accent-primary); margin-top: 0.2rem; font-weight: 600;">🏆 <%= match.matchResult %></div>
                                    <% } %>
                                </div>
                                <div style="flex: 1; text-align: right; font-size: 0.8rem; color: var(--text-muted);"><%= new Date(match.matchDate).toLocaleDateString() %></div>
                            </div>
                        <% }); %>
                    <% } %>
                </div>
            </div>

            <!-- Players & Teams Section -->
            <div class="stat-box glass-panel">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3>Players & Teams</h3>
                    <button class="btn-primary" onclick="showAddTeamModal()" style="font-size: 0.8rem; padding: 0.4rem 1rem;">+ Add Team</button>
                </div>

                <!-- Teams Management -->
                <div id="teams-section">
                    <% if (tournament.teams && tournament.teams.length > 0) { %>
                        <% tournament.teams.forEach(team => { %>
                            <div class="team-card">
                                <div class="team-header">
                                    <h4 style="margin: 0; color: var(--accent-primary);"><%= team.name %></h4>
                                    <button onclick="showSquadManager('<%= team.id %>', '<%= team.name %>')" class="btn-action" style="font-size: 0.7rem;">Manage Squad</button>
                                </div>
                                <div class="squad-list">
                                    <% if (team.squadDetails && team.squadDetails.length > 0) { %>
                                        <% team.squadDetails.forEach(p => { %>
                                            <span class="squad-tag"><%= p.name %></span>
                                        <% }); %>
                                    <% } else { %>
                                        <span style="font-size: 0.8rem; color: var(--text-muted);">No players assigned yet.</span>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="empty-state" style="padding: 1rem; background: rgba(255,255,255,0.02); border-radius: var(--radius-sm); margin-bottom: 2rem;">
                            <p style="font-size: 0.85rem; color: var(--text-muted); text-align: center;">No teams defined. Add teams to organize squads.</p>
                        </div>
                    <% } %>
                </div>

                <h3 style="margin-top: 2rem; border-top: 1px solid var(--border-glass); padding-top: 1.5rem;">Registered Tournament Pool</h3>
                <div style="position: relative; margin: 1rem 0;">
                    <input type="text" id="player-search" placeholder="Search registered players to add to pool..." style="width: 100%; padding: 0.8rem;">
                    <div id="search-results" class="search-results"></div>
                </div>

                <div id="tournament-players" style="margin-top: 1rem;">
                    <% if (players && players.length > 0) { %>
                        <% players.forEach(player => { %>
                            <div class="player-item">
                                <div>
                                    <div style="font-weight: 600;"><%= player.name %></div>
                                    <div style="font-size: 0.8rem; color: var(--text-muted);"><%= player.email %></div>
                                </div>
                                <div style="display: flex; gap: 0.5rem;">
                                    <span style="font-size: 0.7rem; color: var(--text-muted); align-self: center;">
                                        <%= tournament.teams && tournament.teams.some(t => t.squad && t.squad.includes(player.id)) ? 'ASSIGNED' : 'UNASSIGNED' %>
                                    </span>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p style="color: var(--text-muted);">No players in pool yet.</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Squad Manager Modal (Simplified) -->
        <div id="squad-modal" class="glass-panel" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100; padding: 2rem; width: 90%; max-width: 500px; box-shadow: 0 0 50px rgba(0,0,0,0.5);">
            <h3 id="modal-team-name">Manage Squad</h3>
            <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 1.5rem;">Select players from the tournament pool to add to this team.</p>
            
            <div id="pool-selection" style="max-height: 300px; overflow-y: auto; margin-bottom: 2rem;">
                <% if (players && players.length > 0) { %>
                    <% players.forEach(player => { %>
                        <% 
                           const teams = tournament.teams || [];
                           const assignedTeam = teams.find(t => t.squad && t.squad.includes(player.id));
                        %>
                        <label class="player-item squad-player-row" 
                               data-player-id="<%= player.id %>"
                               data-assigned-team-id="<%= assignedTeam ? assignedTeam.id : '' %>"
                               style="cursor: pointer;">
                            <div>
                                <div style="font-weight: 600;"><%= player.name %></div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);"><%= player.email %></div>
                            </div>
                            <input type="checkbox" class="squad-check" value="<%= player.id %>">
                        </label>
                    <% }); %>
                <% } else { %>
                    <p>No players in pool.</p>
                <% } %>
            </div>

            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                <button class="btn-secondary" onclick="hideSquadManager()">Cancel</button>
                <button class="btn-primary" onclick="saveSquad()">Save Squad</button>
            </div>
        </div>
    </main>
    
    <%- include('../partials/footer') %>

    <script>
        const tournamentId = '<%= tournament.id %>';
        const searchInput = document.getElementById('player-search');
        const resultsBox = document.getElementById('search-results');

        searchInput.addEventListener('input', async (e) => {
            const query = e.target.value.trim();
            if (query.length < 2) {
                resultsBox.style.display = 'none';
                return;
            }

            try {
                const res = await fetch(`/organizer/players/search?q=${query}`);
                const players = await res.json();
                
                if (players.length > 0) {
                    resultsBox.innerHTML = players.map(p => `
                        <div class="search-item" onclick="addPlayer('${p.id}', '${p.name}')">
                            ${p.name} (${p.email})
                        </div>
                    `).join('');
                    resultsBox.style.display = 'block';
                } else {
                    resultsBox.style.display = 'none';
                }
            } catch (err) {
                console.error(err);
            }
        });

        async function addPlayer(playerId, playerName) {
            if (!confirm(`Add ${playerName} to this tournament?`)) return;

            try {
                const res = await fetch(`/organizer/tournament/${tournamentId}/add-player`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ playerId })
                });
                
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error adding player: ' + data.error);
                }
            } catch (err) {
                console.error(err);
            }
        }

        // Close search results on click outside
        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !resultsBox.contains(e.target)) {
                resultsBox.style.display = 'none';
            }
        });

        async function showAddTeamModal() {
            const teamName = prompt("Enter Team Name:");
            if (!teamName) return;

            try {
                const res = await fetch(`/organizer/tournament/${tournamentId}/add-team`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ teamName })
                });
                if ((await res.json()).success) {
                    location.reload();
                }
            } catch (err) {
                console.error(err);
            }
        }

        let currentManagingTeamId = null;

        function showSquadManager(teamId, teamName) {
            currentManagingTeamId = teamId;
            document.getElementById('modal-team-name').innerText = `Manage Squad: ${teamName}`;
            
            // Filter player pool: Show unassigned players OR players already in this team
            document.querySelectorAll('.squad-player-row').forEach(row => {
                const assignedTeamId = row.getAttribute('data-assigned-team-id');
                if (!assignedTeamId || assignedTeamId === teamId) {
                    row.style.display = 'flex';
                } else {
                    row.style.display = 'none';
                }
            });

            // Pre-select players already in the squad
            const tournamentData = JSON.parse('<%- JSON.stringify(tournament) %>');
            const team = (tournamentData.teams || []).find(t => t.id === teamId);
            const playerIds = (team && team.squad) || [];
            
            document.querySelectorAll('.squad-check').forEach(check => {
                check.checked = playerIds.includes(check.value);
            });

            document.getElementById('squad-modal').style.display = 'block';
        }

        function hideSquadManager() {
            document.getElementById('squad-modal').style.display = 'none';
        }

        async function saveSquad() {
            const playerIds = Array.from(document.querySelectorAll('.squad-check:checked')).map(c => c.value);
            
            try {
                const res = await fetch(`/organizer/tournament/${tournamentId}/team/${currentManagingTeamId}/update-squad`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ playerIds })
                });
                if ((await res.json()).success) {
                    location.reload();
                }
            } catch (err) {
                console.error(err);
            }
        }

        // Fixture Filtering
        document.getElementById('fixture-search').addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            const items = document.querySelectorAll('#fixtures-list .player-row');
            
            items.forEach(item => {
                const text = item.innerText.toLowerCase();
                item.style.display = text.includes(query) ? '' : 'none';
            });
        });
    </script>
</body>
</html>
